{
  "name": "semantic-code-search",
  "version": "0.2.1",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "scs": "src/cli.ts"
  },
  "scripts": {
    "index": "bun src/cli.ts index",
    "search": "bun src/cli.ts search",
    "mcp": "bun mcp/server.ts",
    "mcp:build": "docker build -t scs-mcp:local .",
    "test": "bun run lint && bun test",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "ignore": "^7.0.5",
    "openai": "^6.44.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "unpdf": "^1.6.2",
    "web-tree-sitter": "0.22.6"
  }
}
